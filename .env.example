# ─── Which observability backend to trace into ──────────────────────────────
# langsmith | mlflow | both   (both = same flow, two panes)
TRACING_BACKEND=langsmith

# ─── LangSmith (used when TRACING_BACKEND is langsmith or both) ──────────────
# Both agents trace to the SAME project.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_PROJECT=dbx-langgraph-distributed-tracing
# LangSmith endpoint — default is fine for SaaS; set for EU/self-hosted.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── MLflow (used when TRACING_BACKEND is mlflow or both) ────────────────────
# Both agents must point at the SAME experiment for their spans to merge.
# IMPORTANT (Databricks): distributed traces merge across services ONLY when
# stored in a Unity Catalog schema — set MLFLOW_UC_CATALOG/SCHEMA below. The
# classic experiment artifact store does NOT merge cross-process spans.
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT=/Users/you@example.com/distributed-tracing-uc
MLFLOW_UC_CATALOG=your_catalog
MLFLOW_UC_SCHEMA=mlflow_traces
MLFLOW_UC_TABLE_PREFIX=dtdemo
# SQL warehouse used to create/query the UC trace tables (CAN USE required).
MLFLOW_TRACING_SQL_WAREHOUSE_ID=your_sql_warehouse_id

# ─── Databricks auth ─────────────────────────────────────────────────────────
# Preferred for local dev: a CLI profile (OAuth token refreshes automatically).
DATABRICKS_CONFIG_PROFILE=DEFAULT
# Alternative (e.g. deployed Databricks App): explicit host + token instead of a
# profile. If DATABRICKS_TOKEN is unset, the code falls back to the profile/SDK.
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi_your_pat_here

# A chat foundation-model / serving endpoint name available in the workspace.
FMAPI_ENDPOINT=databricks-claude-sonnet-4-5

# ─── Unity Catalog data source (product + adverse-event reference tables) ────
# SQL warehouse the Databricks agent queries for field-medical data.
DATABRICKS_WAREHOUSE_ID=your_sql_warehouse_id
UC_CATALOG=main
UC_SCHEMA=field_medical

# ─── Wiring the LangGraph agent to the Databricks agent ──────────────────────
# Local dev: point at the locally-running FastAPI service.
# Deployed:  point at the Databricks App, e.g. https://<app>.databricksapps.com/inquiry
DATABRICKS_AGENT_URL=http://localhost:8010/inquiry
